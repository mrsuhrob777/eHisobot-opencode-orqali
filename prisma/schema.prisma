generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model School {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  login     String   @unique
  password  String
  role      String   // admin | teacher | director | deputy_director
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School?  @relation(fields: [schoolId], references: [id])
}
